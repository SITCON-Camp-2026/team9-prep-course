{
  "name": "sitcon-camp-2026-prep-course-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.mjs",
    "dev": "node scripts/build-profiles.mjs && vite --host 0.0.0.0 --clearScreen false",
    "build": "node scripts/build-profiles.mjs && vite build --base=./",
    "preview": "vite preview --host 0.0.0.0",
    "validate": "node scripts/validate-profiles.mjs",
    "stats": "node scripts/faction-stats.mjs"
  },
  "devDependencies": {
    "vite": "^7.0.0"
  }
}
